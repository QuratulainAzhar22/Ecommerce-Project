@model IEnumerable<MyEcommerceApp.Models.Product>
@if (Model != null )
{
    <div class="container my-4">
    
        @foreach (var item in Model )
        {
            if(item.Id <=18 && item.Id>=10)
            {
            <div class="card mb-3 border shadow-sm">
                <div class="row g-0 align-items-center">
                    <div class="col-md-3 p-3 text-center">
                        <a asp-controller="Frontend" asp-action="ThirdPage" asp-route-id="@item.Id">
                        <img src="@item.ImageUrl" class="img-fluid rounded-start" alt="@item.Name" style="max-height: 200px; object-fit: contain;">
                        </a>
                    </div>
                    
                    <div class="col-md-9">
                        <div class="card-body">
                            <div class="d-flex justify-content-between">
                                <h5 class="card-title fw-normal">
                                   <a asp-controller="Frontend" asp-action="ThirdPage" asp-route-id="@item.Id" class="text-decoration-none text-dark">
                                      @item.Name
                                    </a>
                                </h5>
                                <a asp-controller="Cart" asp-action="SaveForLater" asp-route-id="@item.Id" class="btn btn-sm btn-outline-primary px-3">
                                  <i class="bi bi-heart"></i>
                                </a>
                                
                            </div>
                            
                            <div class="mt-2">
                                <h4 class="d-inline fw-bold">$@item.Price</h4>
                                <span class="text-muted text-decoration-line-through ms-2 small">$@(item.Price + 100)</span> </div>

                            <div class="text-warning small my-2">
                                <i class="bi bi-star-fill"></i>
                                <i class="bi bi-star-fill"></i>
                                <i class="bi bi-star-fill"></i>
                                <i class="bi bi-star-fill"></i>
                                <i class="bi bi-star-half"></i>
                                <span class="text-muted ms-2">7.5 • 154 orders • <span class="text-success">Free Shipping</span></span>
                            </div>

                            <p class="card-text text-secondary small">@item.Description</p>
                            <div class="d-flex justify-content-between">
                            <a asp-controller="Frontend" asp-action="ThirdPage" asp-route-id="@item.Id" class="btn btn-primary">View details</a>
                            <a asp-controller="Cart" asp-action="AddToCart" asp-route-id="@item.Id" class="btn btn-primary">
                              <i class="bi bi-cart-plus"></i> Add to Cart
                            </a>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
            } 
        }
    </div> 
}
else
{
    <div class="alert alert-info">
        No products were found in the database.
    </div>
}
<!-- Toolbar Wrapper: Pushes everything to the right -->
<div class="d-flex justify-content-end align-items-center gap-3 my-4 px-4">
    <nav aria-label="Page navigation">
        <ul class="pagination pagination-sm mb-0 shadow-sm">
            <li class="page-item ">
                <a class="page-link text-dark border-secondary-subtle px-3" asp-controller="Frontend" asp-action="Homepage">
                    1</a>
            </li>
            <li class="page-item active">
                <a class="page-link text-dark border-secondary-subtle px-3" asp-controller="Frontend" asp-action="Homepage_a">2</a>
            </li>
            <li class="page-item">
                <a class="page-link text-dark border-secondary-subtle px-3" asp-controller="Frontend" asp-action="Homepage_b">
                    3
                </a>
            </li>
        </ul>
    </nav>
</div>