@model IEnumerable<MyEcommerceApp.Models.Product>


@if (Model != null)
{
     <div class="row g-3">
  @foreach (var item in Model) {
    <div class="col-md-4 col-sm-6 col-12">
      <div class="card h-100 border-0 shadow-sm p-3">
        
        <div class="text-center mb-3">
          <img src="@item.ImageUrl" class="img-fluid" style="max-height: 180px; object-fit: contain;" alt="@item.Name">
        </div>

        <div class="d-flex justify-content-between align-items-start">
          <div>
            <h5 class="mb-0 fw-bold">$@item.Price</h5>
          </div>
          <a asp-controller="Cart" asp-action="SaveForLater" asp-route-id="@item.Id" class="btn btn-sm btn-outline-primary px-3">
            <i class="bi bi-heart"></i>
          </a>
          
        </div>

        <p class="small text-secondary mb-0">@item.Description</p>
        <div class="mt-auto">
          <a asp-controller="Frontend" asp-action="Thirdpage" asp-route-id="@item.Id" 
            class="text-primary text-decoration-none fw-bold small">
          View details
          </a>
        </div>
        <a asp-controller="Cart" asp-action="AddToCart" asp-route-id="@item.Id" class="btn btn-primary">
           <i class="bi bi-cart-plus"></i> Add to Cart
         </a>
      </div>
    </div>
  }
</div>
}
else
{
    <div class="alert alert-info">
      No products were found in the database.
    </div>
}