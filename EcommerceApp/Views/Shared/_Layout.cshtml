<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>Header</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
  <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons/font/bootstrap-icons.css" rel="stylesheet">
  <style>
    .top-bar {
      border: 2px solid orange;
      padding: 8px 12px;
      background: #f8f9fa;
    }
    .icon-text {
      font-size: 12px;
      text-align: center;
    }
    .icon-text i {
      display: block;
      font-size: 18px;
    }
  </style>
</head>
<body>

<div class="container-fluid top-bar">
  <div class="row align-items-center">

    <!-- Logo -->
    <div class="col-md-2 d-flex align-items-center">
      <i class="bi bi-bag-fill text-primary me-2"></i>
      <strong>Brand</strong>
    </div>

    <!-- Search -->
    <div class="col-md-7">
      <div class="input-group">
        <input type="text" class="form-control" placeholder="Search">
        <select class="form-select" style="max-width: 150px;">
          <option selected>All category</option>
          <option>Electronics</option>
          <option>Clothing</option>
        </select>
        <button class="btn btn-primary">Search</button>
      </div>
    </div>

    <!-- Icons -->
    <div class="col-md-3 d-flex justify-content-end gap-4">
      <div class="icon-text">
        <i class="bi bi-person"></i>
        Profile
      </div>
      <div class="icon-text">
        <i class="bi bi-chat"></i>
        Message
      </div>
      <div class="icon-text">
        <a asp-controller="Order" asp-action="Index" class="text-decoration-none text-muted">
          <i class="bi bi-heart"></i>
          <p class="small mb-0">Orders</p>
        </a>
      </div>
      <div class="icon-text">
        <a asp-controller="Cart" asp-action="Index" class="text-decoration-none text-muted">
        <i class="bi bi-cart"></i>
        <p class="small mb-0">My Cart</p>
        </a>
      </div>
    </div>

  </div>
</div>
</body>

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>Top Bar</title>

  <!-- Bootstrap -->
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">

  <style>
    .topbar {
      background-color: #f8f9fa;
      font-size: 14px;
      padding: 6px 0;
      border-bottom: 1px solid #ddd;
    }
    .topbar a {
      text-decoration: none;
      color: #333;
      margin-right: 15px;
    }
    .topbar a:hover {
      color: #0d6efd;
    }
  </style>
</head>

<body>
<div class="container-fluid topbar">
  <div class="d-flex justify-content-between align-items-center flex-wrap">

    <!-- Left Menu -->
    <div class="d-flex flex-wrap align-items-center">
      <a asp-controller="Home" asp-action="Index" class="text-decoration-none text-dark">
        <i class="bi bi-list me-1"></i> All category
    </a>

    <a asp-controller="Home" asp-action="Index" asp-fragment="recommended-section" class="text-decoration-none text-dark">
        Hot offers
    </a>

    <a href="#" class="text-decoration-none text-dark">Gift boxes</a>
    <a href="#" class="text-decoration-none text-dark">Projects</a>
    <a href="#" class="text-decoration-none text-dark">Menu item</a>
    <a href="#" class="text-decoration-none text-dark">Help <span class="ms-1">▼</span></a>
    </div>

    <!-- Right Menu -->
    <div class="d-flex align-items-center mt-2 mt-md-0">
      <div class="me-3">
        English, USD ▼
      </div>
      <div>
        Ship to <img src="https://flagcdn.com/w20/us.png" alt="flag">
      </div>
    </div>

  </div>
</div>

<!-- Bootstrap Icons (optional) -->
<link href="https://cdn.jsdelivr.net/npm/bootstrap-icons/font/bootstrap-icons.css" rel="stylesheet">

</body>
</html>
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">

  <!-- Bootstrap -->
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">

  <style>
    .breadcrumb-bar {
      background-color: #f1f3f5;
      padding: 10px 15px;
      font-size: 14px;
    }
    .breadcrumb a {
      text-decoration: none;
      color: #6c757d;
    }
    .breadcrumb a:hover {
      color: #0d6efd;
    }
  </style>
</head>
<body>

<div class="container-fluid breadcrumb-bar">
  <nav aria-label="breadcrumb">
    <ol class="breadcrumb mb-0">
      <li class="breadcrumb-item"><a asp-controller="Home" asp-action="Index" class="text-decoration-none text-dark">
        <i class="bi bi-list me-1"></i>Home</a></li>
      <li class="breadcrumb-item"><a asp-controller="Frotend" asp-action="Homepage_a" class="text-decoration-none text-dark">
        <i class="bi bi-list me-1"></i>Clothing</a></li>
      <li class="breadcrumb-item"><a asp-controller="Frotend" asp-action="Homepage_a" class="text-decoration-none text-dark">
        <i class="bi bi-list me-1"></i>Men's wear</a></li>
      <li class="breadcrumb-item active" aria-current="page"><a asp-controller="Frotend" asp-action="Homepage_a" class="text-decoration-none text-dark">
        <i class="bi bi-list me-1"></i>Summer clothing</a></li>
    </ol>
  </nav>
</div>

</body>
</html>
<div class="container-fluid bg-light py-4">
  <div class="row">
    
    <aside class="col-lg-3 d-none d-lg-block">
      <div class="card mb-3 border-0 shadow-sm">
        <div class="card-body">
          <h6 class="fw-bold mb-3">Categories</h6>
          
          <div class="form-check mb-2">
            <a  asp-controller="Frontend" asp-action="Homepage" class="text-decoration-none text-dark">Mobile Accessories</a>
          </div>
          <div class="form-check mb-2">
            <a  asp-controller="Frontend" asp-action="Homepage_a" class="text-decoration-none text-dark">Electronics</a>
          </div>
          <div class="form-check mb-2">
            <a  asp-controller="Frontend" asp-action="Homepage" class="text-decoration-none text-dark">Smartphones</a>
          </div>
          <div class="form-check mb-2">
            <a  asp-controller="Frontend" asp-action="Homepage" class="text-decoration-none text-dark">Modern Tech</a>
          </div>
          <a  asp-controller="Home" asp-action="Homepage" class="text-decoration-none text-dark">See all</a>
          
          <hr>

<div class="d-flex justify-content-between align-items-center mb-3">
    <h6 class="fw-bold mb-0">Brands</h6>
    <a class="text-muted" data-bs-toggle="collapse" href="#brandCollapse" role="button" aria-expanded="true">
        <i class="bi bi-chevron-up" id="brandChevron"></i>
    </a>
</div>

<div class="collapse show" id="brandCollapse">
    <div class="form-check mb-2">
        <input class="form-check-input" type="checkbox" id="samsung" checked>
        <label class="form-check-label small" for="samsung">Samsung</label>
    </div>
    <div class="form-check mb-2">
        <input class="form-check-input" type="checkbox" id="huawei">
        <label class="form-check-label small" for="huawei">Huawei</label>
    </div>
    <div class="form-check mb-2">
        <input class="form-check-input" type="checkbox" id="apple">
        <label class="form-check-label small" for="apple">Apple</label>
    </div>
    <div class="form-check mb-2">
        <input class="form-check-input" type="checkbox" id="pocco">
        <label class="form-check-label small" for="pocco">Pocco</label>
    </div>
    <div class="form-check mb-2">
        <input class="form-check-input" type="checkbox" id="lenovo">
        <label class="form-check-label small" for="lenovo">Lenovo</label>
    </div>
    <a href="#" class="small text-primary text-decoration-none">See all</a>
</div>
          
          <hr>

<div class="d-flex justify-content-between align-items-center mb-3" 
     style="cursor: pointer;" 
     data-bs-toggle="collapse" 
     href="#featuresCollapse" 
     role="button" 
     aria-expanded="true">
    <h6 class="fw-bold mb-0">Features</h6>
    <i class="bi bi-chevron-up text-muted" id="featuresChevron"></i>
</div>

<div class="collapse show" id="featuresCollapse">
    <div class="form-check mb-2">
        <input class="form-check-input" type="checkbox" id="metallic" checked>
        <label class="form-check-label small" for="metallic">Metallic</label>
    </div>
    <div class="form-check mb-2">
        <input class="form-check-input" type="checkbox" id="plasticcover" checked>
        <label class="form-check-label small" for="plasticcover">Plastic Cover</label>
    </div>
    <div class="form-check mb-2">
        <input class="form-check-input" type="checkbox" id="ram8gb" checked>
        <label class="form-check-label small" for="ram8gb">8GB Ram</label>
    </div>
    <div class="form-check mb-2">
        <input class="form-check-input" type="checkbox" id="superpower" checked>
        <label class="form-check-label small" for="superpower">Super Power</label>
    </div>
    <div class="form-check mb-2">
        <input class="form-check-input" type="checkbox" id="largememory" checked>
        <label class="form-check-label small" for="largememory">Large Memory</label>
    </div>
    <a href="#" class="small text-primary text-decoration-none">See all</a>
</div>
          <hr>
          <a class="d-flex justify-content-between align-items-center text-decoration-none text-dark fw-bold mb-3" 
           data-bs-toggle="collapse" href="#priceCollapse" role="button" aria-expanded="true">
            Price range
            <i class="bi bi-chevron-up small text-muted"></i>
        </a>
        <div class="collapse show" id="priceCollapse">
            <div class="position-relative mb-4">
                <input type="range" class="form-range" min="0" max="999999" id="priceRange">
            </div>
            <div class="row g-2">
                <div class="col-6">
                    <label class="small text-muted">Min</label>
                    <input type="number" class="form-control form-control-sm" placeholder="0">
                </div>
                <div class="col-6">
                    <label class="small text-muted">Max</label>
                    <input type="number" class="form-control form-control-sm" placeholder="999999">
                </div>
            </div>
            <button class="btn btn-outline-primary btn-sm w-100 mt-3 shadow-sm">Apply</button>
        </div>
    </div>
    <hr>
    <a class="d-flex justify-content-between align-items-center text-decoration-none text-dark fw-bold mb-3" 
           data-bs-toggle="collapse" href="#conditionCollapse" role="button">
            Condition
            <i class="bi bi-chevron-up small text-muted"></i>
        </a>
        <div class="collapse show" id="conditionCollapse">
            <div class="form-check mb-2">
                <input class="form-check-input" type="radio" name="condition" id="any" checked>
                <label class="form-check-label small" for="any">Any</label>
            </div>
            <div class="form-check mb-2">
                <input class="form-check-input" type="radio" name="condition" id="refurbished">
                <label class="form-check-label small" for="refurbished">Refurbished</label>
            </div>
            <div class="form-check mb-2">
                <input class="form-check-input" type="radio" name="condition" id="brandNew">
                <label class="form-check-label small" for="brandNew">Brand new</label>
            </div>
            <div class="form-check mb-2">
                <input class="form-check-input" type="radio" name="condition" id="oldItems">
                <label class="form-check-label small" for="oldItems">Old items</label>
            </div>
            <hr>
          <a class="d-flex justify-content-between align-items-center text-decoration-none text-dark fw-bold mb-3" 
           data-bs-toggle="collapse" href="#ratingsCollapse" role="button">
            Ratings
            <i class="bi bi-chevron-up small text-muted"></i>
        </a>
        <div class="collapse show" id="ratingsCollapse">
            @for (int i = 5; i >= 2; i--)
            {
                <div class="form-check mb-2">
                    <input class="form-check-input" type="checkbox" id="star@i">
                    <label class="form-check-label text-warning small" for="star@i">
                        @for (int s = 1; s <= 5; s++)
                        {
                            <i class="bi @(s <= i ? "bi-star-fill" : "bi-star text-muted")"></i>
                        }
                    </label>
                </div>
            }
        </div>
          <hr>
          
          <h6 class="fw-bold mb-3">Manufacturer</h6>
          </div>
      </div>
    </aside>

    <main class="col-lg-9">
      
      <div class="card mb-4 border-0 shadow-sm">
        <div class="card-body d-flex align-items-center justify-content-between py-2">
          <div>
            <span class="text-muted small">12,911 items in <strong class="text-dark">Mobile accessory</strong></span>
          </div>
          <div class="d-flex align-items-center gap-3">
            <div class="form-check mb-0 small">
              <input class="form-check-input" type="checkbox" id="verified">
              <label class="form-check-label" for="verified">Verified only</label>
            </div>
            <select class="form-select form-select-sm w-auto">
              <option>Featured</option>
            </select>
            <div class="btn-group">
              <button class="btn btn-outline-secondary btn-sm active"><i class="bi bi-grid-fill"></i></button>
              <button class="btn btn-outline-secondary btn-sm"><i class="bi bi-list"></i></button>
            </div>
          </div>
        </div>
      </div>

<html>

    <main role="main">@RenderBody()</main>
<section class="py-5 bg-blue">
    <div class="container">
        <div class="row justify-content-center text-center">
            <div class="col-md-6">
                <h5 class="fw-bold mb-2">Subscribe on our newsletter</h5>
                <p class="text-secondary small mb-4">
                    Get daily news on upcoming offers from many suppliers all over the world
                </p>

                <div class="input-group mb-3 mx-auto" style="max-width: 450px;">
                    <span class="input-group-text bg-white border-end-0">
                        <i class="bi bi-envelope text-muted"></i> </span>
                    <input type="email" class="form-control border-start-0" placeholder="Email" aria-label="Email">
                    <button class="btn btn-primary px-4" type="button">Subscribe</button>
                </div>
            </div>
        </div>
    </div>
</section>
    <footer class="mt-5">
        <div class="container">
           
            <div class="row">
                 <!-- Brand and Socials -->
            <div class="col-lg-3 col-md-12 mb-4">
