                <p class="text-muted small" style="max-width: 250px;">
                    Best marketplace for connecting with global suppliers and sourcing quality products.
                </p>
                <div class="d-flex gap-2">
                    <a href="#" class="btn btn-sm btn-secondary rounded-circle"><i class="bi bi-facebook"></i></a>
                    <a href="#" class="btn btn-sm btn-secondary rounded-circle"><i class="bi bi-twitter"></i></a>
                    <a href="#" class="btn btn-sm btn-secondary rounded-circle"><i class="bi bi-linkedin"></i></a>
                    <a href="#" class="btn btn-sm btn-secondary rounded-circle"><i class="bi bi-instagram"></i></a>
                    <a href="#" class="btn btn-sm btn-secondary rounded-circle"><i class="bi bi-youtube"></i></a>
                </div>
            </div>
                   <!-- Links Column 1 -->
            <div class="col-6 col-md-3 col-lg-2 mb-3">
                <h6 class="fw-bold text-dark">About</h6>
                <ul class="list-unstyled small">
                    <li class="mb-2"><a href="#" class="text-muted text-decoration-none">About Us</a></li>
                    <li class="mb-2"><a href="#" class="text-muted text-decoration-none">Find store</a></li>
                    <li class="mb-2"><a href="#" class="text-muted text-decoration-none">Categories</a></li>
                    <li class="mb-2"><a href="#" class="text-muted text-decoration-none">Blogs</a></li>
                </ul>
            </div>

            <!-- Links Column 2 -->
            <div class="col-6 col-md-3 col-lg-2 mb-3">
                <h6 class="fw-bold text-dark">Partnership</h6>
                <ul class="list-unstyled small">
                    <li class="mb-2"><a href="#" class="text-muted text-decoration-none">About Us</a></li>
                    <li class="mb-2"><a href="#" class="text-muted text-decoration-none">Find store</a></li>
                    <li class="mb-2"><a href="#" class="text-muted text-decoration-none">Categories</a></li>
                    <li class="mb-2"><a href="#" class="text-muted text-decoration-none">Blogs</a></li>
                </ul>
            </div>

            <!-- Links Column 3 -->
            <div class="col-6 col-md-3 col-lg-2 mb-3">
