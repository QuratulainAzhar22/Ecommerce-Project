
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>Header</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
  <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons/font/bootstrap-icons.css" rel="stylesheet">
  <style>
    .top-bar {
      border: 2px solid orange;
      padding: 8px 12px;
      background: #f8f9fa;
    }
    .icon-text {
      font-size: 12px;
      text-align: center;
    }
    .icon-text i {
      display: block;
      font-size: 18px;
    }
  </style>
</head>
<body>

<div class="container-fluid top-bar">
  <div class="row align-items-center">

    <!-- Logo -->
    <div class="col-md-2 d-flex align-items-center">
      <i class="bi bi-bag-fill text-primary me-2"></i>
      <strong>Brand</strong>
    </div>

    <!-- Search -->
    <div class="col-md-7">
      <div class="input-group">
        <input type="text" class="form-control" placeholder="Search">
        <select class="form-select" style="max-width: 150px;">
          <option selected>All category</option>
          <option>Electronics</option>
          <option>Clothing</option>
        </select>
        <button class="btn btn-primary">Search</button>
      </div>
    </div>

    <!-- Icons -->
    <div class="col-md-3 d-flex justify-content-end gap-4">
      <div class="icon-text">
        <i class="bi bi-person"></i>
        Profile
      </div>
      <div class="icon-text">
        <i class="bi bi-chat"></i>
        Message
      </div>
      <div class="icon-text">
        <a asp-controller="Order" asp-action="Index" class="text-decoration-none text-muted">
          <i class="bi bi-heart"></i>
          <p class="small mb-0">Orders</p>
        </a>
      </div>
      <div class="icon-text">
        <a asp-controller="Cart" asp-action="Index" class="text-decoration-none text-muted">
        <i class="bi bi-cart"></i>
        <p class="small mb-0">My Cart</p>
        </a>
      </div>
    </div>

  </div>
</div>
</body>

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>Top Bar</title>

  <!-- Bootstrap -->
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">

  <style>
    .topbar {
      background-color: #f8f9fa;
      font-size: 14px;
      padding: 6px 0;
      border-bottom: 1px solid #ddd;
    }
    .topbar a {
      text-decoration: none;
      color: #333;
      margin-right: 15px;
    }
    .topbar a:hover {
      color: #0d6efd;
    }
  </style>
</head>

<body>
<div class="container-fluid topbar">
  <div class="d-flex justify-content-between align-items-center flex-wrap">

    <!-- Left Menu -->
    <div class="d-flex flex-wrap align-items-center">
      <a asp-controller="Home" asp-action="Index" class="text-decoration-none text-dark">
        <i class="bi bi-list me-1"></i> All category
    </a>

    <a asp-controller="Home" asp-action="Index" asp-fragment="recommended-section" class="text-decoration-none text-dark">
        Hot offers
    </a>

    <a href="#" class="text-decoration-none text-dark">Gift boxes</a>
    <a href="#" class="text-decoration-none text-dark">Projects</a>
    <a href="#" class="text-decoration-none text-dark">Menu item</a>
    <a href="#" class="text-decoration-none text-dark">Help <span class="ms-1">▼</span></a>
    </div>

    <!-- Right Menu -->
    <div class="d-flex align-items-center mt-2 mt-md-0">
      <div class="me-3">
        English, USD ▼
      </div>
      <div>
        Ship to <img src="https://flagcdn.com/w20/us.png" alt="flag">
      </div>
    </div>

  </div>
</div>

<!-- Bootstrap Icons (optional) -->
<link href="https://cdn.jsdelivr.net/npm/bootstrap-icons/font/bootstrap-icons.css" rel="stylesheet">

</body>
</html>
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">

  <!-- Bootstrap -->
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">

  <style>
    .breadcrumb-bar {
      background-color: #f1f3f5;
      padding: 10px 15px;
      font-size: 14px;
    }
    .breadcrumb a {
      text-decoration: none;
      color: #6c757d;
    }
    .breadcrumb a:hover {
      color: #0d6efd;
    }
  </style>
</head>
<body>

<div class="container-fluid breadcrumb-bar">
  <nav aria-label="breadcrumb">
    <ol class="breadcrumb mb-0">
      <li class="breadcrumb-item"><a href="#">Home</a></li>
      <li class="breadcrumb-item"><a href="#">Clothing</a></li>
      <li class="breadcrumb-item"><a href="#">Men's wear</a></li>
      <li class="breadcrumb-item active" aria-current="page">Summer clothing</li>
    </ol>
  </nav>
</div>

</body>
</html>

<html>
